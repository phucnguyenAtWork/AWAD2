{
  "name": "AWAD2",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "turbo": "^2.8.21",
    "typescript": "5.9.2",
    "@types/bun": "latest"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.1.0"
  },
  "packageManager": "bun@1.1.34",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "dependencies": {
    "bcrypt": "6.0.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.2",
    "mysql2": "^3.20.0"
  },
  "overrides": {
    "esbuild": "^0.25.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  },
  "module": "index.ts",
  "type": "module"
}
