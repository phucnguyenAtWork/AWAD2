@startuml SmartFinance Class Diagram

skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam class {
  BackgroundColor #FAFAFA
  BorderColor #37474F
  ArrowColor #37474F
}

' ============================================================
'  AUTH SERVICE
' ============================================================

package "Auth Service (port 4002)" #E3F2FD {

  class AuthController <<Controller>> {
    + POST /auth/register(body): AuthResponse
    + POST /auth/login(body): AuthResponse
    + GET /auth/me(): UserProfile
    - handleError(err: unknown): ErrorResponse
  }

  class AuthService <<Service>> {
    + register(input): {user, accessToken}
    + login(input): {user, accessToken}
    + profile(userId: string): AuthUser
  }

  class UsersRepository <<Repository>> {
    + findById(id: string): AuthUser | undefined
    + findByPhoneOrEmail(phone, email): AuthUser | undefined
    + createUser(data): AuthUser
    + existsWithPhone(phone: string): boolean
    + existsWithEmail(email: string): boolean
  }

  class PasswordUtils <<Utility>> {
    + hashPassword(password: string): Promise<string>
    + verifyPassword(password, hash): Promise<boolean>
  }

  class TokenUtils <<Utility>> {
    + signAccessToken(userId: string): string
    + verifyAccessToken(token: string): AccessTokenPayload
  }

  class RateLimiter <<Middleware>> {
    - store: Map<string, {windowStart, hits}>
    + middleware(request): void | 429
  }

  class RequireAuth_Auth <<Middleware>> {
    + requireAuth(request): void | 401
  }

  AuthController --> AuthService
  AuthService --> UsersRepository
  AuthService --> PasswordUtils
  AuthService --> TokenUtils
  AuthController --> RateLimiter
  AuthController --> RequireAuth_Auth
}

' ============================================================
'  FINANCE SERVICE
' ============================================================

package "Finance Service (port 4001)" #E8F5E9 {

  class AccountsController <<Controller>> {
    + GET /(query): Account[]
    + POST /(body): Account
    + GET /:id(params): Account
    + PATCH /:id(params, body): Account
    + DELETE /:id(params): Account
  }

  class CategoriesController <<Controller>> {
    + GET /(query): Category[]
    + POST /(body): Category
    + GET /:id(params): Category
    + PATCH /:id(params, body): Category
    + DELETE /:id(params): Category
  }

  class TransactionsController <<Controller>> {
    + GET /(query): Transaction[]
    + POST /(body): Transaction
    + GET /:id(params): Transaction
    + PATCH /:id(params, body): Transaction
    + DELETE /:id(params): Transaction
  }

  class BudgetsController <<Controller>> {
    + GET /(query): Budget[]
    + POST /(body): Budget
    + GET /:id(params): Budget
    + PATCH /:id(params, body): Budget
    + DELETE /:id(params): Budget
  }

  class AccountsService <<Service>> {
    + list(userId?: string): Account[]
    + get(id: string): Account | undefined
    + create(data: AccountInput): Account
    + update(id, data): Account | undefined
    + delete(id: string): Account | undefined
  }

  class CategoriesService <<Service>> {
    + list(accountId?: string): Category[]
    + get(id: string): Category | undefined
    + create(data: CategoryInput): Category
    + update(id, data): Category | undefined
    + delete(id: string): Category | undefined
  }

  class TransactionsService <<Service>> {
    + list(userId?: string): Transaction[]
    + get(id: string): Transaction | undefined
    + create(data: TransactionInput): Transaction
    + update(id, data): Transaction | undefined
    + delete(id: string): Transaction | undefined
    - resolveDefaultCategory(userId): string
  }

  class BudgetsService <<Service>> {
    + list(accountId?: string): Budget[]
    + get(id: string): Budget | undefined
    + create(data: BudgetInput): Budget
    + update(id, data): Budget | undefined
    + delete(id: string): Budget | undefined
  }

  class AccountsRepository <<Repository>> {
    + listAccounts(userId?): Account[]
    + getAccount(id): Account | undefined
    + createAccount(input): Account
    + updateAccount(id, input): Account | undefined
    + deleteAccount(id): Account | undefined
  }

  class CategoriesRepository <<Repository>> {
    + listCategories(accountId?): Category[]
    + getCategory(id): Category | undefined
    + createCategory(input): Category
    + updateCategory(id, input): Category | undefined
    + deleteCategory(id): Category | undefined
    + seedDefaultCategories(accountId): void
    + getUncategorized(accountId): Category | undefined
  }

  class TransactionsRepository <<Repository>> {
    + listTransactions(userId?): Transaction[]
    + getTransaction(id): Transaction | undefined
    + createTransaction(input): Transaction
    + updateTransaction(id, input): Transaction | undefined
    + deleteTransaction(id): Transaction | undefined
  }

  class BudgetsRepository <<Repository>> {
    + listBudgets(accountId?): Budget[]
    + getBudget(id): Budget | undefined
    + createBudget(input): Budget
    + updateBudget(id, input): Budget | undefined
    + deleteBudget(id): Budget | undefined
  }

  class RequireAuth_Finance <<Middleware>> {
    + authGuardConfig: GuardConfig
    + resolveUserId(request): {userId: string}
  }

  AccountsController --> AccountsService
  CategoriesController --> CategoriesService
  TransactionsController --> TransactionsService
  BudgetsController --> BudgetsService

  AccountsService --> AccountsRepository
  AccountsService --> CategoriesRepository : seeds defaults
  CategoriesService --> CategoriesRepository
  TransactionsService --> TransactionsRepository
  TransactionsService --> CategoriesRepository : resolve default
  BudgetsService --> BudgetsRepository

  AccountsController --> RequireAuth_Finance
  CategoriesController --> RequireAuth_Finance
  TransactionsController --> RequireAuth_Finance
  BudgetsController --> RequireAuth_Finance
}

' ============================================================
'  INSIGHTS SERVICE (TypeScript — port 4003)
' ============================================================

package "Insights Service — TS (port 4003)" #FFF3E0 {

  class ChatController <<Controller>> {
    + POST /insights/chat(body): ChatResponse
    + GET /insights/logs(query): ChatLog[]
    + GET /insights/logs/:id(params): ChatLog
    + DELETE /insights/logs/:id(params): {success}
  }

  class ChatService_TS <<Service>> {
    + chat(input: ChatInput): {response, log}
    + list(accountId, limit?): ChatLog[]
    + get(id: number): ChatLog | undefined
    + delete(id: number): ChatLog | undefined
    - fetchFinanceContext(token): FinanceContext
    - computeAnalytics(ctx, currency): Analytics
    - buildSystemPrompt(ctx): string
    - parseAction(text): ActionPayload | null
    - executeAction(action, token, ctx): string
  }

  class ModelClient_TS <<ExternalClient>> {
    - GEMINI_URL: string
    + chat(input: ModelChatRequest): ModelChatResponse
  }

  class ChatLogsRepository_TS <<Repository>> {
    + create(log: NewChatLog): ChatLog
    + listByAccount(accountId, limit): ChatLog[]
    + get(id: number): ChatLog | undefined
    + delete(id: number): ChatLog | undefined
  }

  class RequireAuth_Insights <<Middleware>> {
    + authGuardConfig: GuardConfig
    + resolveUserId(request): {userId: string}
  }

  ChatController --> ChatService_TS
  ChatService_TS --> ChatLogsRepository_TS
  ChatService_TS --> ModelClient_TS
  ChatController --> RequireAuth_Insights
}

' ============================================================
'  RAG PIPELINE (Python FastAPI — port 4004)
' ============================================================

package "RAG Pipeline — Python (port 4004)" #FCE4EC {

  class RAGRouter <<FastAPI>> {
    + POST /insights/chat(body): ChatResponse
    + GET /insights/logs(query): ChatLogRow[]
    + GET /insights/logs/{id}: ChatLogRow
    + DELETE /insights/logs/{id}: {success}
    + GET /health(): {status, engine}
  }

  class RAGChatService <<Service>> {
    + chat(user_id, token, prompt, currency?): ChatResponse
    - request_id: UUID
    - timer: monotonic
  }

  class ContextBuilder <<Retrieval>> {
    - _cache: TTLCache[str, (FinanceContext, Analytics)]
    + build_context(token, account_id): (ctx, analytics, currency)
    + compute_analytics(ctx, currency): Analytics
    + cap_context(ctx): FinanceContext
  }

  class PromptTemplate <<Prompt>> {
    + build_system_prompt(ctx, analytics, currency, display?): str
  }

  class ActionParser <<Validation>> {
    + parse_action(text): ActionPayload | None
    + strip_action_blocks(text): str
    - _validate_action_data(payload): void
  }

  class ActionExecutor <<Executor>> {
    + execute_action(action, token, ctx, currency): str
  }

  class FinanceClient <<HTTPClient>> {
    + fetch_context(token): FinanceContext
    + create_transaction(token, data): dict
    + create_budget(token, data): dict
    + create_category(token, data): dict
  }

  class GeminiClient <<ExternalClient>> {
    + chat(system_instruction, messages): ModelResponse
    - prompt_tokens: int | None
    - response_tokens: int | None
  }

  class JWTAuth <<Middleware>> {
    + verify_token(authorization): user_id
    + extract_raw_token(authorization): str
  }

  class Database <<Repository>> {
    + get_pool(): aiomysql.Pool
    + check_connection(): void
    + create_log(...): ChatLogRow
    + list_logs(account_id, limit): ChatLogRow[]
    + get_log(id): ChatLogRow | None
    + delete_log(id): ChatLogRow | None
  }

  RAGRouter --> RAGChatService
  RAGRouter --> JWTAuth
  RAGChatService --> ContextBuilder
  RAGChatService --> PromptTemplate
  RAGChatService --> ActionParser
  RAGChatService --> ActionExecutor
  RAGChatService --> GeminiClient
  RAGChatService --> Database
  ContextBuilder --> FinanceClient
  ActionExecutor --> FinanceClient
}

' ============================================================
'  PYDANTIC MODELS (used across Python pipeline)
' ============================================================

package "Pydantic Models" #F3E5F5 {

  class FinanceContext <<Model>> {
    accounts: list[Account]
    categories: list[Category]
    transactions: list[Transaction]
    budgets: list[Budget]
  }

  class ActionPayload <<Model>> {
    action: ActionType
    data: dict[str, Any]
  }

  class TransactionActionData <<Model>> {
    type: str {INCOME|EXPENSE}
    amount: float > 0
    description: str
    categoryId: str | None
    occurredAt: str | None
  }

  class BudgetActionData <<Model>> {
    accountId: str
    categoryId: str | None
    amountLimit: float > 0
    period: str
    startDate: str
    endDate: str
  }

  class CategoryActionData <<Model>> {
    name: str
    type: str {INCOME|EXPENSE}
    icon: str | None
  }

  class ChatLogRow <<Model>> {
    id: int
    account_id: str
    user_query: str | None
    ai_response: str | None
    context_snapshot: Any
    action: Any
    model_name: str | None
    latency_ms: int | None
    prompt_tokens: int | None
    response_tokens: int | None
    request_id: str | None
    timestamp: datetime
  }

  ActionPayload --> TransactionActionData : validates
  ActionPayload --> BudgetActionData : validates
  ActionPayload --> CategoryActionData : validates
}

' ============================================================
'  CROSS-SERVICE RELATIONSHIPS
' ============================================================

ChatService_TS ..> AccountsController : "HTTP GET /accounts\n(RAG context)"
ChatService_TS ..> CategoriesController : "HTTP GET /categories\n(RAG context)"
ChatService_TS ..> TransactionsController : "HTTP GET /transactions\n(RAG context)"
ChatService_TS ..> BudgetsController : "HTTP GET /budgets\n(RAG context)"
ChatService_TS ..> TransactionsController : "HTTP POST /transactions\n(action execution)"
ChatService_TS ..> BudgetsController : "HTTP POST /budgets\n(action execution)"

FinanceClient ..> AccountsController : "HTTP GET\n(RAG context)"
FinanceClient ..> CategoriesController : "HTTP GET/POST"
FinanceClient ..> TransactionsController : "HTTP GET/POST"
FinanceClient ..> BudgetsController : "HTTP GET/POST"

class "Gemini API" as GeminiAPI <<External>>
ModelClient_TS ..> GeminiAPI : "HTTPS POST\ngenerateContent"
GeminiClient ..> GeminiAPI : "HTTPS POST\ngenerateContent"

@enduml
