  @startuml SmartFinance Architecture

  skinparam component {
    BackgroundColor #FAFAFA
    BorderColor #37474F
  }
  skinparam node {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
  }
  skinparam database {
    BackgroundColor #FFFDE7
    BorderColor #5D4037
  }
  skinparam cloud {
    BackgroundColor #F3E5F5
    BorderColor #6A1B9A
  }

  node "Client Browser" {
    [React SPA\n(Vite + TailwindCSS)\nport 5173] as frontend
  }

  node "Bun Runtime" {
    package "Auth Service\nport 4002" as auth_svc {
      [Auth Controller] as auth_ctrl
      [Auth Service] as auth_biz
      [Users Repository] as auth_repo
      [Rate Limiter] as rate_lim
    }

    package "Finance Service\nport 4001" as fin_svc {
      [Accounts Controller] as acc_ctrl
      [Categories Controller] as cat_ctrl
      [Transactions Controller] as txn_ctrl
      [Budgets Controller] as bud_ctrl
      [Services Layer] as fin_biz
      [Repositories Layer] as fin_repo
    }

    package "Insights Service (TS)\nport 4003" as ins_svc {
      [Chat Controller] as chat_ctrl
      [Chat Service\n(TS RAG)] as chat_biz
      [Model Client] as model_client
      [ChatLogs Repository] as chat_repo
    }
  }

  node "Python Runtime" {
    package "RAG Pipeline (FastAPI)\nport 4004" as rag_svc {
      [FastAPI Router] as rag_router
      [Chat Service\n(Python RAG)] as rag_chat
      [Context Builder\n(TTL Cache)] as rag_ctx
      [Action Parser\n(Pydantic)] as rag_action
      [Finance Client\n(httpx)] as rag_fin
      [Model Client\n(Gemini)] as rag_model
    }
  }

  node "Docker Compose" {
    database "MySQL Server" as mysql {
      [auth] as auth_db
      [finance] as fin_db
      [insights] as ins_db
    }
    [phpMyAdmin\nport 8080] as pma
  }

  cloud "Google Cloud" {
    [Gemini 2.5\nFlash Lite API] as gemini
  }

  ' --- Frontend connections ---
  frontend --> auth_ctrl : "HTTP REST\n(login/register)"
  frontend --> acc_ctrl : "HTTP REST\n(CRUD)"
  frontend --> cat_ctrl : "HTTP REST"
  frontend --> txn_ctrl : "HTTP REST"
  frontend --> bud_ctrl : "HTTP REST"
  frontend --> rag_router : "HTTP REST\n(chat/logs)\nport 4004"

  ' --- Auth internal ---
  auth_ctrl --> auth_biz
  auth_biz --> auth_repo
  auth_repo --> auth_db
  auth_ctrl --> rate_lim

  ' --- Finance internal ---
  acc_ctrl --> fin_biz
  cat_ctrl --> fin_biz
  txn_ctrl --> fin_biz
  bud_ctrl --> fin_biz
  fin_biz --> fin_repo
  fin_repo --> fin_db

  ' --- Insights TS internal ---
  chat_ctrl --> chat_biz
  chat_biz --> chat_repo
  chat_biz --> model_client
  chat_repo --> ins_db
  model_client --> gemini : "HTTPS"

  ' --- RAG Pipeline (Python) internal ---
  rag_router --> rag_chat
  rag_chat --> rag_ctx : "build + cache context"
  rag_chat --> rag_action : "parse + validate"
  rag_ctx --> rag_fin
  rag_chat --> rag_model
  rag_model --> gemini : "HTTPS\n(generateContent)"
  rag_chat --> ins_db : "aiomysql\n(chat_logs)"

  ' --- RAG cross-service ---
  rag_fin --> acc_ctrl : "HTTP GET\n(RAG context)"
  rag_fin --> txn_ctrl : "HTTP GET/POST\n(context + action)"
  rag_fin --> cat_ctrl : "HTTP GET/POST"
  rag_fin --> bud_ctrl : "HTTP GET/POST"

  ' --- TS cross-service (legacy) ---
  chat_biz ..> acc_ctrl : "HTTP GET\n(RAG context)"
  chat_biz ..> txn_ctrl : "HTTP POST\n(action exec)"

  ' --- phpMyAdmin ---
  pma --> mysql

  @enduml
