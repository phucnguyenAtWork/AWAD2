MYSQL_HOST=localhost
MYSQL_ROOT_PASSWORD=changeme-root
MYSQL_USER=appuser
MYSQL_PASSWORD=changeme-app
MYSQL_PORT=3306
DB_POOL_SIZE=10

# Service-specific DB names
FINANCE_DATABASE=finance
AUTH_DATABASE=auth

INSIGHTS_DATABASE=insights

PHPMYADMIN_PORT=8080
# Example full URL (optional override per service)
