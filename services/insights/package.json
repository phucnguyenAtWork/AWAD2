{
  "name": "insights",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun dist/index.js",
    "build": "bun build src/index.ts --outdir dist --target bun --sourcemap",
    "typecheck": "bunx tsc --noEmit",
    "lint": "bunx eslint . --ext .ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit push"
  },
  "dependencies": {
    "elysia": "^1.4.28",
    "@elysiajs/openapi": "^1.4.14",
    "@elysiajs/cors": "^1.0.6",
    "dotenv": "^17.3.1",
    "zod": "^4.3.6",
    "drizzle-orm": "^0.45.2",
    "mysql2": "^3.20.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^6.0.2",
    "eslint": "^9.39.4",
    "@typescript-eslint/parser": "^8.57.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "drizzle-kit": "^0.31.10"
  }
}
